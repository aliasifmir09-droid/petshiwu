{
  "name": "pet-ecommerce-backend",
  "version": "1.0.0",
  "description": "Backend API for pet e-commerce platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "set NODE_PATH=../node_modules&&nodemon src/server.ts",
    "dev:unix": "NODE_PATH=../node_modules nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/utils/seed.ts",
    "seed-products": "ts-node src/utils/seedProductsFixed.ts",
    "seed-pet-types": "ts-node src/utils/seedPetTypes.ts",
    "check-pet-types": "ts-node src/utils/checkPetTypes.ts",
    "fix-review-index": "ts-node src/utils/fixReviewIndex.ts",
    "add-slugs": "ts-node src/utils/addSlugsToExistingData.ts",
    "cleanup-pets": "ts-node src/utils/cleanupPetTypes.ts",
    "update-password-expiry": "ts-node src/utils/updatePasswordExpiry.ts",
    "fix-category-index": "ts-node src/utils/fixCategoryIndex.ts",
    "force-drop-category-name-index": "ts-node src/utils/forceDropCategoryNameIndex.ts",
    "update-category-levels": "ts-node src/utils/updateCategoryLevels.ts",
    "grant-permissions": "ts-node src/utils/grantPermissions.ts",
    "create-customer": "ts-node src/utils/createCustomer.ts",
    "find-duplicates": "ts-node src/utils/findAndRemoveDuplicates.ts",
    "remove-duplicates": "ts-node src/utils/findAndRemoveDuplicates.ts --delete",
    "format-product-descriptions": "ts-node src/utils/formatAllProductDescriptions.ts",
    "delete-all-products": "ts-node src/utils/deleteAllProducts.ts"
  },
  "dependencies": {
    "@types/node": "^20.10.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.8.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "isomorphic-dompurify": "^2.30.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "dompurify": "^3.3.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
