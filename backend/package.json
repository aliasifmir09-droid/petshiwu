{
  "name": "pet-ecommerce-backend",
  "version": "1.0.0",
  "description": "Backend API for pet e-commerce platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "set NODE_PATH=../node_modules&&nodemon src/server.ts",
    "dev:unix": "NODE_PATH=../node_modules nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/utils/seed.ts",
    "seed-products": "ts-node src/utils/seedProductsFixed.ts",
    "seed-pet-types": "ts-node src/utils/seedPetTypes.ts",
    "check-pet-types": "ts-node src/utils/checkPetTypes.ts",
    "fix-review-index": "ts-node src/utils/fixReviewIndex.ts",
    "add-slugs": "ts-node src/utils/addSlugsToExistingData.ts",
    "cleanup-pets": "ts-node src/utils/cleanupPetTypes.ts",
    "update-password-expiry": "ts-node src/utils/updatePasswordExpiry.ts",
    "fix-category-index": "ts-node src/utils/fixCategoryIndex.ts",
    "force-drop-category-name-index": "ts-node src/utils/forceDropCategoryNameIndex.ts",
    "update-category-levels": "ts-node src/utils/updateCategoryLevels.ts",
    "grant-permissions": "ts-node src/utils/grantPermissions.ts",
    "create-customer": "ts-node src/utils/createCustomer.ts",
    "find-duplicates": "ts-node src/scripts/findAndRemoveDuplicates.ts",
    "remove-duplicates": "ts-node src/scripts/findAndRemoveDuplicates.ts --delete",
    "list-products": "ts-node src/scripts/listAllProducts.ts",
    "check-db": "ts-node src/scripts/checkDatabase.ts",
    "format-product-descriptions": "ts-node src/utils/formatAllProductDescriptions.ts",
    "delete-all-products": "ts-node src/scripts/deleteAllProducts.ts",
    "delete-recent-products": "ts-node src/scripts/deleteRecentProducts.ts",
    "fix-category-hierarchy": "ts-node src/scripts/fixCategoryHierarchy.ts",
    "check-pet-types-db": "ts-node src/scripts/checkPetTypesInDB.ts",
    "add-other-animals": "ts-node src/scripts/addOtherAnimalsPetType.ts",
    "check-small-pet-products": "ts-node src/scripts/checkSmallPetProducts.ts",
    "fix-small-pet-products": "ts-node src/scripts/fixSmallPetProducts.ts",
    "fix-product-stock": "ts-node src/utils/fixProductStock.ts",
    "analyze-indexes": "ts-node src/utils/analyzeIndexUsage.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "fix-sku-index": "ts-node src/utils/fixSkuIndex.ts",
    "seed-email-templates": "ts-node src/utils/seedEmailTemplates.ts",
    "fix-email": "ts-node src/utils/fixEmail.ts"
  },
  "dependencies": {
    "@types/bull": "^3.15.9",
    "@types/node": "^20.10.6",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cloudinary": "^2.8.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.11",
    "redis": "^5.10.0",
    "resend": "^6.5.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^7.0.4",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/winston": "^2.4.4",
    "dompurify": "^3.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
